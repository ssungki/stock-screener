# ── 키움 REST API (openapi.kiwoom.com 에서 발급) ──
# ⚠️ 이 파일을 복사해 ".env" 로 만들고 실제 값을 넣으세요. .env 는 절대 깃/채팅에 노출 금지.
KIWOOM_APPKEY=여기에_앱키
KIWOOM_SECRETKEY=여기에_시크릿키
# 실전 https://api.kiwoom.com / 모의 https://mockapi.kiwoom.com
KIWOOM_REST_BASE=https://api.kiwoom.com

# ── 디스코드 알림 (웹훅 URL) ──
DISCORD_WEBHOOK_URL=

# ── 카카오 "나에게 보내기" ──
KAKAO_REST_API_KEY=
# 최초 1회 OAuth 로 발급받은 refresh_token (이후 access_token 자동 갱신)
KAKAO_REFRESH_TOKEN=

# ── 신호 판정 파라미터 ──
# 3분봉 이평선 기간들
MA_PERIODS=5,10,20,60,120
# 수렴 판정: 이평선 밴드폭(최고-최저)/현재가 가 이 값 이하이면 "모임"
SQUEEZE_THRESHOLD=0.015
# 확산 판정: 밴드폭이 수렴최저폭의 이 배수 이상으로 터져야 "퍼짐"(가짜신호 거름)
EXPANSION_RATIO=4.0
# 수렴(스퀴즈) 탐색 구간(직전 봉 수). 3분봉 기준 30개=최근 90분
LOOKBACK=30
# 같은 종목 재알림 쿨다운(분)
ALERT_COOLDOWN_MIN=30
# 일봉 상승추세 판정 이평기간(이 이평 위 + 우상향이면 후보)
DAILY_TREND_MA=20

# ── 폴링(거래대금 상위 스캔) ──
# 분봉 단위(분). 1=1분봉(단타·빠른 포착) 3=3분봉(잔진동 적고 수렴 패턴 안정)
TICK_MIN=3
# 거래대금 상위 몇 종목을 감시할지 (연속조회로 페이지 이어받아 수집)
TOP_N=200
# 스캔 주기(초). 90 = 1분반마다 한 바퀴(3분봉 캔들보다 짧게)
POLL_INTERVAL_SEC=90
# API 호출 사이 간격(초) — 키움 레이트리밋 보호
REQ_DELAY_SEC=0.3
# 시장: 000=전체 001=코스피 101=코스닥  /  거래소: 1=KRX 2=NXT 3=통합
MRKT_TP=000
STEX_TP=1
# 장 시간(분 단위, KST). 540=09:00, 930=15:30
MARKET_OPEN_HM=540
MARKET_CLOSE_HM=930
